{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/quoxai/volt/schemas/signature.schema.json",
  "title": "VOLT Signature Record",
  "description": "A signature/attestation record for a VOLT Evidence Bundle (v0.1). See SPEC.md section 15.",
  "type": "object",
  "required": [
    "sig_version",
    "sig_type",
    "key_id",
    "signed_ts",
    "scope",
    "message",
    "signature"
  ],
  "properties": {
    "sig_version": {
      "type": "string",
      "description": "Signature record version",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "sig_type": {
      "type": "string",
      "description": "Signature algorithm (Ed25519 recommended)",
      "enum": ["ed25519"]
    },
    "key_id": {
      "type": "string",
      "description": "Stable identifier for the signing key (DID or fingerprint)",
      "minLength": 1
    },
    "signed_ts": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the signature was created",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "scope": {
      "type": "string",
      "description": "Scope of the signature (v0.1 supports 'bundle' only)",
      "enum": ["bundle"]
    },
    "message": {
      "type": "object",
      "description": "The data that was signed",
      "required": [
        "run_id",
        "bundle_id",
        "hash_alg",
        "first_event_hash",
        "last_event_hash",
        "event_count"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "hash_alg": {
          "type": "string",
          "const": "sha256"
        },
        "first_event_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "last_event_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "event_count": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "signature": {
      "type": "string",
      "description": "Base64-encoded signature bytes",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
