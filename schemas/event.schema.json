{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/quoxai/volt/schemas/event.schema.json",
  "title": "VOLT Event",
  "description": "A single VOLT trace event (v0.1). See SPEC.md section 6.",
  "type": "object",
  "required": [
    "volt_version",
    "event_id",
    "run_id",
    "ts",
    "seq",
    "event_type",
    "actor",
    "context",
    "payload",
    "prev_hash",
    "hash"
  ],
  "properties": {
    "volt_version": {
      "type": "string",
      "description": "Protocol version, e.g. \"0.1\"",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "event_id": {
      "type": "string",
      "description": "Unique identifier for this event within the run",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for the run",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "description": "ISO 8601 timestamp with UTC Z suffix",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "seq": {
      "type": "integer",
      "description": "Monotonically increasing sequence number, starting at 1",
      "minimum": 1
    },
    "event_type": {
      "type": "string",
      "description": "Dotted event type path, e.g. \"tool.call.executed\"",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "actor": {
      "type": "object",
      "description": "Who caused or observed this event",
      "required": ["actor_type", "actor_id"],
      "properties": {
        "actor_type": {
          "type": "string",
          "enum": ["agent", "human", "system", "tool", "runner"]
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        },
        "org_id": {
          "type": "string"
        },
        "team_id": {
          "type": "string"
        },
        "runner_id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "description": "Correlation and linkage to AEE/AOCL",
      "required": ["correlation_id"],
      "properties": {
        "correlation_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_event_id": {
          "type": "string"
        },
        "aee_envelope_id": {
          "type": "string"
        },
        "aee_message_id": {
          "type": "string"
        },
        "aocl_policy_id": {
          "type": "string"
        },
        "aocl_decision_id": {
          "type": "string"
        },
        "workspace_id": {
          "type": "string"
        },
        "project_id": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "payload": {
      "type": "object",
      "description": "Event-type-specific data (privacy-safe)",
      "additionalProperties": true
    },
    "prev_hash": {
      "type": "string",
      "description": "Hex SHA-256 hash of the previous event (64 zeros for genesis)",
      "pattern": "^[0-9a-f]{64}$"
    },
    "hash": {
      "type": "string",
      "description": "Hex SHA-256 hash of this event (computed over canonical form with hash field removed)",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": true
}
